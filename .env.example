# Copy this file to `.env` and fill in the values from your Supabase project:
# Supabase Dashboard -> Project Settings -> API
#
# Both are safe to expose in the browser (the anon key is designed to be
# public; access is restricted by row-level security in supabase/schema.sql).
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
